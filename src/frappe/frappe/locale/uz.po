#. Description of the 'Auto Name' (Data) field in DocType 'Customize Form'
#: frappe/custom/doctype/customize_form/customize_form.json
msgid "Naming Options:\n"
"<ol><li><b>field:[fieldname]</b> - By Field</li><li><b>naming_series:</b> - By Naming Series (field called naming_series must be present)</li><li><b>Prompt</b> - Prompt user for a name</li><li><b>[series]</b> - Series by prefix (separated by a dot); for example PRE.#####</li>\n"
"<li><b>format:EXAMPLE-{MM}morewords{fieldname1}-{fieldname2}-{#####}</b> - Replace all braced words (fieldnames, date words (DD, MM, YY), series) with their value. Outside braces, any characters can be used.</li></ol>"
msgstr "Nomlash imkoniyatlari:\n"
"<ol><li><b>maydon:[maydon nomi]</b> - Maydon bo'yicha</li><li><b>nomlash_series:</b> - Nomlash_series bo'yicha (naming_series deb nomlangan maydon mavjud bo'lishi kerak)</li><li><b>So'rov</b> - Foydalanuvchidan nom so'rash</li><li><b>[seriya]</b> - Prefiks bo'yicha ketma-ketlik (nuqta bilan ajratilgan); masalan, PRE.#####</li>\n"
"<li><b>format:EXAMPLE-{MM}morewords{fieldname1}-{fieldname2}-{#####}</b> - Qavs ichidagi barcha so'zlarni (maydon nomlari, sana so'zlari (KK, OO, YY), seriya) ularning qiymati bilan almashtiring. Qavslar tashqarisida istalgan belgilardan foydalanish mumkin.</li></ol>"

