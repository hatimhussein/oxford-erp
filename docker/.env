# =============================================================================
# FrappeDev / OxfordERP — Docker environment (arrdh.com/oxforderp)
# =============================================================================

# Docker base image (bench CLI version — NOT Frappe framework version; see README)
# Official tags: frappe/bench:v5.x — there is no frappe/bench:v17 tag.
BENCH_IMAGE_TAG=v5.31.0

# Site (must match folder under data/bench/sites/ — check with: ls data/bench/sites)
SITE_NAME=development.localhost
ADMIN_PASSWORD=admin
HOST_NAME=https://arrdh.com/oxforderp

# Database
MARIADB_ROOT_PASSWORD=admin
MARIADB_PORT=3306

# Web — bound to 127.0.0.1 only (see docker-compose.yml)
WEB_PORT=8000
SOCKETIO_PORT=9000
# Docker nginx reverse proxy (host SSL → this port)
PROXY_PORT=8088

# Frappe
DEVELOPER_MODE=0
BENCH_DIR=/home/frappe/frappe-bench

# Paths inside the container (do not change unless you customize mounts)
WORKSPACE_SRC=/workspace/src

# Bench init flags
SKIP_ASSETS_BUILD=0
FORCE_REINSTALL=0
